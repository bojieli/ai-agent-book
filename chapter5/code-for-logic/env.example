# 复制本文件为 .env 并填入你的密钥
# 必填其一：OpenAI API Key（直连）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 通用兜底：未配置 OPENAI_API_KEY 时自动改走 OpenRouter；
# 另外默认模型 gpt-5.6-luna（gpt-5.x）直连 OpenAI 需组织实名认证，
# 因此设置了本 key 时会优先走 OpenRouter（route openai/gpt-5.6-luna）。
# OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxx

# 可选：切换到兼容 OpenAI 协议的服务端点
# OPENAI_BASE_URL=https://api.openai.com/v1

# 可选：默认模型(不填则用 gpt-5.6-luna)
MODEL=gpt-5.6-luna
